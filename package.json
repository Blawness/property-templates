  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": ["@blawness/admin-kit", "esbuild", "sharp"]
  }
